# ─────────────────────────────────────────────────────────────
# Eugen Krieger – Entrümpelung & Service — Environment variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.eugen-krieger-entruempelung.de

# ── Booking notifications ────────────────────────────────────
# The owner receives every booking by e-mail. Two options:
#
# Option A (recommended): Resend (https://resend.com) — free tier available
RESEND_API_KEY=
# The address bookings are sent TO (the owner)
BOOKING_NOTIFY_EMAIL=eugenkrieger.entruempelung@gmail.com
# The verified sender address for Resend (e.g. buchung@deine-domain.de)
BOOKING_FROM_EMAIL=buchung@eugen-krieger-entruempelung.de

# Option B: classic SMTP (GMX, IONOS, etc.) — used if RESEND_API_KEY is empty
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
